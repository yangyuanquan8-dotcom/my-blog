---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPostsByTag, getAllTags } from '../../../utils/posts';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map(tag => ({
    params: { tag: tag.toLowerCase().replace(/\s+/g, '-') },
  }));
}

const { tag } = Astro.params;
const displayTag = (tag || '').toLowerCase().replace(/-/g, ' ');
const posts = await getPostsByTag(displayTag);
---
<BaseLayout title={`Tag: ${displayTag}`}>
  <h1 class="text-2xl font-bold mb-2 font-[system-ui]">
    Posts tagged <span class="text-[var(--color-accent)]">#{displayTag}</span>
  </h1>
  <p class="text-[var(--color-text-secondary)] mb-8">{posts.length} 篇文章</p>
  <div class="grid gap-4">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        slug={post.slug}
        date={post.data.date.toISOString()}
        description={post.data.description}
        tags={post.data.tags}
      />
    ))}
  </div>
  <a href="/" class="inline-block mt-8 text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-[system-ui]">&larr; All posts</a>
</BaseLayout>
