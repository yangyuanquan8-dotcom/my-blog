---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import TagBadge from '../components/TagBadge.astro';
import { getSortedPosts, getAllTags } from '../utils/posts';

const posts = await getSortedPosts();
const allTags = await getAllTags();
---
<BaseLayout>
  <section class="mb-12">
    <h1 class="text-3xl font-bold mb-2 font-[system-ui]">Hey, I'm a blogger</h1>
    <p class="text-[var(--color-text-secondary)] text-lg">
      记录所学、所想、所建。Welcome to my corner of the internet.
    </p>
  </section>

  {
    allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        {allTags.map(tag => <TagBadge {tag} />)}
      </div>
    )
  }

  <section>
    {
      posts.length === 0 ? (
        <p class="text-[var(--color-text-secondary)]">还没有文章，马上就来。</p>
      ) : (
        <div class="grid gap-4">
          {posts.map(post => (
            <PostCard
              title={post.data.title}
              slug={post.slug}
              date={post.data.date.toISOString()}
              description={post.data.description}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
