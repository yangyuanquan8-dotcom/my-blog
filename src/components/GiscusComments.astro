<!--
  Giscus comments component.
  Configure your repo at https://giscus.app before using this.
  Update data-repo and data-repo-id below.
-->
<section class="mt-12 pt-8 border-t border-[var(--color-border)]">
  <h3 class="text-lg font-bold mb-4 font-[system-ui]">Comments</h3>
  <script
    src="https://giscus.app/client.js"
    data-repo="YOUR_GITHUB_USERNAME/YOUR_REPO"
    data-repo-id="YOUR_REPO_ID"
    data-category="General"
    data-category-id="DIC_kwDOB_"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="preferred_color_scheme"
    data-lang="en"
    crossorigin="anonymous"
    async
  >
  </script>
  <noscript>
    <p class="text-sm text-[var(--color-text-secondary)]">
      Comments require JavaScript. <a href="https://github.com/giscus/giscus" class="text-[var(--color-accent)]">Powered by Giscus</a>.
    </p>
  </noscript>
</section>
